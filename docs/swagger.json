    "host": "localhost:8082",
    "basePath": "/transaction/v1",
    "paths": {
        "/create": {
            "post": {
                "description": "Processes a new wallet transaction, updating the user's current balance and generating a transaction record.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "summary": "Create Wallet Transaction  User",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Insert your access external: Bearer \u003cexternal\u003e",
                        "name": "Authorization",
                        "in": "header",
                        "required": true
                    },
                    {
                        "description": "Payload create wallet transaction user",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/transaction_dto.CreateTransactionRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "allOf": [
                                {
                                    "$ref": "#/definitions/helpers.SuccessResponse"
                                },
                                {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "$ref": "#/definitions/transaction_dto.CreateTransactionResponse"
                                        }
                                    }
                                }
                            ]
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/helpers.BadRequestResponse"
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "$ref": "#/definitions/helpers.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/helpers.ErrorResponse"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "errs.FieldError": {
            "type": "object",
            "properties": {
                "field": {
                    "type": "string"
                },
                "message": {
                    "type": "string"
                }
            }
        },
        "helpers.BadRequestResponse": {
            "type": "object",
            "properties": {
                "code": {
                    "type": "string",
                    "example": "BAD_REQUEST"
                },
                "errors": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/errs.FieldError"
                    }
                },
                "message": {
                    "type": "string",
                    "example": "validation error"
                }
            }
        },
        "helpers.ErrorResponse": {
            "type": "object",
            "properties": {
                "code": {
                    "type": "string"
                },
                "message": {
                    "type": "string"
                }
            }
        },
        "helpers.SuccessResponse": {
            "type": "object",
            "properties": {
                "code": {
                    "type": "string",
                    "example": "SUCCESS"
                },
                "data": {},
                "message": {
                    "type": "string"
                }
            }
        },
        "transaction.Status": {
            "type": "string",
            "enum": [
                "PENDING",
                "SUCCESS",
                "FAILED",
                "REVERSED"
            ],
            "x-enum-varnames": [
                "Pending",
                "Success",
                "Failed",
                "Reversed"
            ]
        },
        "transaction.Type": {
            "type": "string",
            "enum": [
                "TOPUP",
                "PURCHASE",
                "REFUND"
            ],
            "x-enum-varnames": [
                "Topup",
                "Purchase",
                "Refund"
            ]
        },
        "transaction_dto.CreateTransactionRequest": {
            "type": "object",
            "required": [
                "amount",
                "description",
                "transactionType"
            ],
            "properties": {
                "amount": {
                    "type": "number"
                },
                "description": {
                    "type": "string"
                },
                "transactionType": {
                    "enum": [
                        "TOPUP",
                        "PURCHASE",
                        "REFUND"
                    ],
                    "allOf": [
                        {
                            "$ref": "#/definitions/transaction.Type"
                        }
                    ]
                }
            }
        },
        "transaction_dto.CreateTransactionResponse": {
            "type": "object",
            "properties": {
                "reference": {
                    "type": "string"
                },
                "transactionStatus": {
                    "$ref": "#/definitions/transaction.Status"
                }
            }
        }
    }
}